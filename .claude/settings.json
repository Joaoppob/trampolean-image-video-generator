{
  "permissions": {
    "allow": [
      "Bash(ffmpeg:*)",
      "Bash(ffprobe:*)",
      "Bash(curl:*)",
      "Bash(node:*)",
      "Bash(mkdir:*)",
      "Bash(where:*)",
      "Bash(which:*)",
      "Read(./RAG/**)",
      "Read(./output/**)",
      "Read(./examples/**)",
      "Write(./output/**)"
    ],
    "deny": [
      "Read(./**/.credentials.json)",
      "Read(~/.claude/.credentials.json)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/scope-guard.cjs\""
          }
        ]
      }
    ]
  }
}
