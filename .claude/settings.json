{
  "permissions": {
    "allow": [
      "Bash(ffmpeg:*)",
      "Bash(ffprobe:*)",
      "Bash(curl -L:*)",
      "Bash(curl -X PUT --data-binary:*)",
      "Bash(node:*)",
      "Bash(where:*)",
      "Bash(which:*)",
      "Task",
      "Skill",
      "Read",
      "Glob",
      "Grep",
      "mcp__higgsfield__balance",
      "mcp__higgsfield__show_plans_and_credits",
      "mcp__higgsfield__media_upload",
      "mcp__higgsfield__media_confirm",
      "mcp__higgsfield__generate_image",
      "mcp__higgsfield__generate_video",
      "mcp__higgsfield__job_status",
      "Read(./RAG/**)",
      "Read(./output/**)",
      "Read(./examples/**)",
      "Write(./output/**)"
    ],
    "deny": [
      "Read(./**/.credentials.json)",
      "Read(~/.claude/.credentials.json)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/scope-guard.cjs\""
          }
        ]
      }
    ]
  }
}
