{
  "permissions": {
    "allow": [
      "Bash(ffmpeg:*)",
      "Bash(ffprobe:*)",
      "Bash(curl -L:*)",
      "Bash(node scripts/:*)",
      "Bash(node .claude/skills/:*)",
      "Bash(where:*)",
      "Bash(which:*)",
      "Bash(higgsfield:*)",
      "Bash(hf:*)",
      "Bash(npm install -g @higgsfield/cli:*)",
      "Task",
      "Skill",
      "Read",
      "Glob",
      "Grep",
      "Read(./RAG/**)",
      "Read(./projects/**/output/**)",
      "Read(./examples/**)",
      "Write(./projects/**/output/**)"
    ],
    "deny": [
      "Read(./**/.credentials.json)",
      "Read(~/.claude/.credentials.json)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/scope-guard.cjs\""
          }
        ]
      }
    ]
  }
}
