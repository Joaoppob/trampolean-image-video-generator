# === Saídas geradas (não versionar — só os .gitkeep das pastas) ===
# Multi-projeto: output vive em projects/<nome>/output/ (e templates/<nome>/output/).
# Os globs **/output/ cobrem qualquer projeto/template de uma vez.
**/output/imagens/*
!**/output/imagens/.gitkeep
**/output/clips/*
!**/output/clips/.gitkeep
**/output/reels/*
!**/output/reels/.gitkeep

# === Temporários e estado de pipeline (por projeto) ===
tmp/
**/output/.pipeline-state.json
**/output/.pipeline-state.json.corrupt-*
**/output/.credit-ledger.jsonl
**/output/.intake-state.json
.claude/state/.review-cadence.json
.claude/state/.jotaro-profile.json
.claude/state/*.corrupt-*
**/*.tmp

# === Credenciais — NUNCA versionar (OAuth é por-usuário, em ~/.claude/) ===
.credentials.json
*.credentials.json
.env
.env.*
*.secret
*.key
*.token

# === Lixo de SO / editor ===
.DS_Store
Thumbs.db
desktop.ini
