# === Outputs (nao versionar, so os .gitkeep das pastas) ===
# Multi-projeto: output em projects/<nome>/output/ (e templates/<nome>/output/).
# Os globs **/output/ cobrem qualquer projeto/template de uma vez.
**/output/imagens/*
!**/output/imagens/.gitkeep
**/output/clips/*
!**/output/clips/.gitkeep
**/output/reels/*
!**/output/reels/.gitkeep

# === Caixa de entrada Raw/ (conteudo NAO versionado, so o esqueleto) ===
# JB dropa material aqui e o Jotaro organiza via /importa (move pra projects/).
# Ignora todo o conteudo solto, mantem o esqueleto rastreavel (.gitkeep + README).
Raw/**
!Raw/.gitkeep
!Raw/README.md

# === Temporarios e estado de pipeline (por projeto) ===
tmp/
**/output/.pipeline-state.json
**/output/.pipeline-state.json.corrupt-*
**/output/.pipeline-state.json.lock
**/output/.credit-ledger.jsonl
**/output/.intake-state.json
**/output/.anim-*.json
**/output/.last-*
.claude/state/.review-cadence.json
.claude/state/.jotaro-profile.json
.claude/state/.gate-pass.json
.claude/state/*.corrupt-*
**/*.tmp

# === Credenciais - NUNCA versionar (OAuth e por-usuario, em ~/.claude/) ===
.credentials.json
*.credentials.json
.env
.env.*
*.secret
*.key
*.token

# === Lixo de SO / editor ===
.DS_Store
Thumbs.db
desktop.ini