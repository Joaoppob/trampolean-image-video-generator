{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trampolean.local/schemas/identity.schema.json",
  "title": "Trampolean identity contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "refs",
    "anchor_textual",
    "estilo",
    "paleta",
    "narrativa_resumo",
    "tom"
  ],
  "properties": {
    "refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^RAG/identidade-visual/([^/.]+/)*[^/]+\\.(png|jpg|jpeg|webp)$"
      }
    },
    "anchor_textual": {
      "type": "string",
      "minLength": 80
    },
    "estilo": {
      "type": "string",
      "minLength": 10
    },
    "paleta": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "narrativa_resumo": {
      "type": "string",
      "minLength": 20
    },
    "tom": {
      "type": "string",
      "minLength": 10
    }
  }
}
