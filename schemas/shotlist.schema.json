{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trampolean.local/schemas/shotlist.schema.json",
  "title": "Trampolean shot-list contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "campanha",
    "cliente",
    "formato",
    "duracao_total_seg",
    "modelo",
    "referencias_obrigatorias",
    "anchor_personagem",
    "cenas",
    "gate_consistencia"
  ],
  "properties": {
    "campanha": { "type": "string", "minLength": 1 },
    "cliente": { "type": "string", "minLength": 1 },
    "data": { "type": "string" },
    "round": { "type": "integer" },
    "objetivo": { "type": "string" },
    "formato": {
      "type": "string",
      "pattern": "9:16"
    },
    "duracao_total_seg": {
      "type": "integer",
      "minimum": 4
    },
    "modelo": {
      "type": "string",
      "pattern": "nano_banana_pro"
    },
    "referencias_obrigatorias": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "string",
        "pattern": "^RAG/identidade-visual/[^/]+\\.(png|jpg|jpeg|webp)$"
      }
    },
    "anchor_personagem": {
      "type": "string",
      "minLength": 40
    },
    "cenas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["n", "tag", "tempo_seg", "intencao", "prompt", "salvar_em"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "tag": { "type": "string", "minLength": 1 },
          "tempo_seg": {
            "type": "string",
            "pattern": "^[0-9]+-[0-9]+$"
          },
          "intencao": { "type": "string", "minLength": 10 },
          "prompt": {
            "type": "string",
            "minLength": 80,
            "pattern": "9:16"
          },
          "salvar_em": {
            "type": "string",
            "pattern": "^output/imagens/[^/]+\\.png$"
          }
        }
      }
    },
    "gate_consistencia": {
      "type": "object",
      "minProperties": 1
    }
  }
}
