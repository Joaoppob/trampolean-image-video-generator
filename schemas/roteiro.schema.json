{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trampolean.local/schemas/roteiro.schema.json",
  "title": "Trampolean roteiro contract",
  "type": "object",
  "required": ["titulo", "gancho", "desenvolvimento", "cta", "plataforma", "tom"],
  "properties": {
    "titulo": { "type": "string" },
    "gancho": { "type": "string", "description": "Primeira frase ou imagem. O que prende nos 2s iniciais." },
    "desenvolvimento": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["beat", "descricao"],
        "properties": {
          "beat": { "type": "integer" },
          "descricao": { "type": "string" }
        }
      }
    },
    "cta": { "type": "string" },
    "plataforma": { "type": "string" },
    "duracao_alvo_seg": { "type": "integer" },
    "tom": { "type": "string" },
    "referencias_usadas": { "type": "array", "items": { "type": "string" } }
  }
}
