{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trampolean.local/schemas/cinematografia.schema.json",
  "title": "Trampolean cinematografia nivel-100 contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["campanha", "cliente", "formato", "cenas"],
  "properties": {
    "campanha": { "type": "string", "minLength": 1 },
    "cliente": { "type": "string", "minLength": 1 },
    "formato": { "type": "string", "pattern": "9:16" },
    "diretriz_global": {
      "type": "string",
      "description": "Regra visual que governa o reel inteiro: premium por coerencia, nao por excesso de craft."
    },
    "cenas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["n", "objetivo_visual", "frame_1", "luz", "composicao", "camera", "cor", "anti_ia"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "objetivo_visual": { "type": "string", "minLength": 20 },
          "frame_1": { "type": "string", "minLength": 20 },
          "luz": { "type": "string", "minLength": 20 },
          "composicao": { "type": "string", "minLength": 20 },
          "camera": { "type": "string", "minLength": 20 },
          "cor": { "type": "string", "minLength": 20 },
          "anti_ia": {
            "type": "object",
            "additionalProperties": false,
            "required": ["evitar", "foco"],
            "properties": {
              "evitar": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
              "foco": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } }
            }
          }
        }
      }
    }
  }
}
